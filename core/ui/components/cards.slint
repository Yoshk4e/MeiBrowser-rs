import { Palette } from "../theme.slint";
import {
    IconBolt,
    IconBox,
    IconKey,
    IconCheck,
    IconFile,
    IconFolder,
} from "../icons.slint";

export component ModeCard inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <string> icon; // "bolt" | "box" | "key"
    callback clicked();

    width: 220px;
    height: 180px;
    clip: true; // longer subtitles shouldn't be able to blow past the card edge
    border-radius: Palette.radius-xl;
    background: touch.has-hover ? Palette.surface-hover : Palette.surface;
    border-width: 1px;
    border-color: touch.has-hover ? Palette.accent : Palette.border;

    drop-shadow-color: touch.has-hover ? #e8ac3d2e : #00000000;
    drop-shadow-blur: 18px;
    drop-shadow-offset-y: 6px;

    animate background, border-color, drop-shadow-blur {
        duration: 180ms;
        easing: ease-out;
    }

    // lift on hover
    property <length> lift: touch.has-hover ? -4px : 0px;
    y: lift;
    animate y {
        duration: 180ms;
        easing: ease-out;
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    VerticalLayout {
        padding: 20px;
        spacing: 10px;
        alignment: start;

        Rectangle {
            width: 40px;
            height: 40px;
            border-radius: Palette.radius-md;
            background: Palette.accent-dim;

            if root.icon == "bolt": IconBolt {
                size: 20px;
                color: Palette.accent;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }
            if root.icon == "box": IconBox {
                size: 20px;
                color: Palette.accent;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }
            if root.icon == "key": IconKey {
                size: 20px;
                color: Palette.accent;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }
        }

        Text {
            text: root.title;
            font-size: 18px;
            font-weight: 800;
            color: Palette.text-primary;
        }

        Text {
            text: root.subtitle;
            font-size: 12px;
            color: Palette.text-muted;
            wrap: word-wrap;
        }
    }
}

export component GameTile inherits Rectangle {
    in property <string> tag;
    in property <string> name;
    in property <bool> selected;
    callback clicked();

    width: 150px;
    height: 90px;
    border-radius: Palette.radius-lg;
    background: selected ? Palette.accent-dim : touch.has-hover ? Palette.surface-hover : Palette.surface;
    border-width: selected ? 2px : 1px;
    border-color: selected ? Palette.accent : (touch.has-hover ? Palette.border-hover : Palette.border);
    animate background, border-color, border-width {
        duration: 150ms;
        easing: ease-out;
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    VerticalLayout {
        alignment: center;
        spacing: 4px;
        Text {
            text: root.tag;
            horizontal-alignment: center;
            font-size: 20px;
            font-weight: 800;
            color: selected ? Palette.accent : Palette.text-primary;
        }

        Text {
            text: root.name;
            horizontal-alignment: center;
            font-size: 11px;
            color: Palette.text-muted;
            wrap: word-wrap;
        }
    }

    // Per-game badge, pinned to the top corner of the tile. This is what the
    // derived theme is generated from on the Rust side when this tile is
    // clicked (see `theme_gen.rs` / `on_select_game`).
    Rectangle {
        width: 36px;
        height: 36px;
        x: parent.width - self.width + 10px;
        y: -12px;
        border-radius: 18px;
        background: Palette.surface-raised;
        border-width: selected ? 2px : 1px;
        border-color: selected ? Palette.accent : Palette.border;
        clip: true;
        animate border-color, border-width {
            duration: 150ms;
            easing: ease-out;
        }

        drop-shadow-color: #00000055;
        drop-shadow-blur: 6px;
        drop-shadow-offset-y: 2px;

        if root.tag == "GI": Image {
            source: @image-url("../assets/gi-icon.png");
            width: 100%;
            height: 100%;
            image-fit: cover;
        }
        if root.tag == "HSR": Image {
            source: @image-url("../assets/hsr-icon.png");
            width: 100%;
            height: 100%;
            image-fit: cover;
        }
        if root.tag == "ZZZ": Image {
            source: @image-url("../assets/zzz-icon.png");
            width: 100%;
            height: 100%;
            image-fit: cover;
        }
    }
}

export component PackageRow inherits Rectangle {
    in property <string> label;
    in property <string> description;
    in property <bool> selected;
    callback clicked();

    height: 64px;
    border-radius: Palette.radius-md;
    background: selected ? Palette.accent-dim : touch.has-hover ? Palette.surface-hover : Palette.surface;
    border-width: selected ? 2px : 1px;
    border-color: selected ? Palette.accent : Palette.border;
    animate background, border-color {
        duration: 150ms;
        easing: ease-out;
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    HorizontalLayout {
        padding: 14px;
        spacing: 12px;
        Rectangle {
            width: 20px;
            height: 20px;
            border-radius: 10px;
            border-width: 2px;
            border-color: selected ? Palette.accent : #4a5060;
            background: transparent;
            y: (parent.height - self.height) / 2;
            if selected: Rectangle {
                width: 10px;
                height: 10px;
                border-radius: 5px;
                background: Palette.accent;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }
        }

        VerticalLayout {
            alignment: center;
            spacing: 2px;
            Text {
                text: root.label;
                color: Palette.text-primary;
                font-weight: 700;
                font-size: 14px;
            }

            Text {
                text: root.description;
                color: Palette.text-muted;
                font-size: 11px;
            }
        }
    }
}

export component FileRow inherits Rectangle {
    in property <string> name;
    in property <string> size-text;
    in property <string> count-text;
    in property <bool> is-file;
    in property <bool> selected;
    callback row-clicked();
    callback check-clicked();

    height: 46px;
    border-radius: Palette.radius-sm;
    background: touch.has-hover ? Palette.surface-hover : transparent;
    animate background { duration: 120ms; }

    touch := TouchArea {
        clicked => {
            root.row-clicked();
        }
    }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 10px;

        Rectangle {
            width: 18px;
            height: 18px;
            y: (parent.height - self.height) / 2;
            border-radius: 4px;
            border-width: 2px;
            border-color: root.selected ? Palette.accent : #4a5060;
            background: root.selected ? Palette.accent : transparent;
            animate background, border-color { duration: 120ms; }
            check := TouchArea {
                clicked => {
                    root.check-clicked();
                }
            }

            if root.selected: IconCheck {
                size: 11px;
                color: Palette.on-accent;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }
        }

        if root.is-file: IconFile {
            size: 15px;
            color: Palette.text-muted;
            y: (parent.height - self.height) / 2;
        }
        if !root.is-file: IconFolder {
            size: 15px;
            color: Palette.accent;
            y: (parent.height - self.height) / 2;
        }

        Text {
            text: root.name;
            color: Palette.text-primary;
            font-size: 13px;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }

        Text {
            text: root.count-text;
            color: Palette.text-faint;
            font-size: 11px;
            vertical-alignment: center;
        }

        Text {
            text: root.size-text;
            color: Palette.text-muted;
            font-size: 12px;
            vertical-alignment: center;
        }
    }
}
