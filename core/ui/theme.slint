export global Palette {
    in-out property <brush> bg: #0f1115;
    in-out property <brush> surface: #171a21;
    in-out property <brush> surface-raised: #12141a;
    in-out property <brush> surface-hover: #1d222c;
    in-out property <brush> border: #262b36;
    in-out property <brush> border-hover: #3a4152;

    in-out property <brush> accent: #e8ac3d;
    in-out property <brush> accent-hover: #f0b94d;
    in-out property <brush> accent-pressed: #d9a441;
    in-out property <brush> accent-dim: #2a2411;
    in-out property <brush> on-accent: #14171f;

    out property <brush> text-primary: #ffffff;
    out property <brush> text-secondary: #c7cbd4;
    out property <brush> text-muted: #8b93a3;
    out property <brush> text-faint: #6b7280;

    out property <brush> danger-bg: #3a1c1c;
    out property <brush> danger-border: #7a3030;
    out property <brush> danger-text: #ff9d9d;

    out property <brush> shadow: #00000066;

    out property <length> radius-sm: 8px;
    out property <length> radius-md: 10px;
    out property <length> radius-lg: 14px;
    out property <length> radius-xl: 18px;

    out property <length> space-xs: 6px;
    out property <length> space-sm: 10px;
    out property <length> space-md: 16px;
    out property <length> space-lg: 24px;
    out property <length> space-xl: 32px;
}
