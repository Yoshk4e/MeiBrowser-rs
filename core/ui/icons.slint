component IconBase inherits Path {
    in property <length> size: 20px;
    in property <brush> color: white;
    width: root.size;
    height: root.size;
    fill: transparent;
    stroke: root.color;
    stroke-width: 1.8px;
}

export component IconBolt inherits IconBase {
    fill: root.color;
    stroke: transparent;
    commands: "M 13 2 L 3 14 L 12 14 L 11 22 L 21 10 L 12 10 Z";
}

export component IconBox inherits IconBase {
    commands: "M 3 7 L 12 3 L 21 7 L 21 17 L 12 21 L 3 17 Z M 3 7 L 12 11 L 21 7 M 12 11 L 12 21";
}

export component IconKey inherits IconBase {
    commands: "M 3 11 A 4 4 0 1 0 11 11 A 4 4 0 1 0 3 11 M 11 11 L 21 11 M 21 11 L 21 15 M 17 11 L 17 14";
}

export component IconCheck inherits IconBase {
    stroke-width: 2.4px;
    commands: "M 4 12.5 L 9.5 18 L 20 5";
}

export component IconArrowLeft inherits IconBase {
    commands: "M 19 12 L 5 12 M 5 12 L 11 6 M 5 12 L 11 18";
}

export component IconFile inherits IconBase {
    commands: "M 6 2 L 14 2 L 18 6 L 18 22 L 6 22 Z M 14 2 L 14 6 L 18 6";
}

export component IconFolder inherits IconBase {
    commands: "M 3 6 L 10 6 L 12 8 L 21 8 L 21 19 L 3 19 Z";
}

export component IconDownload inherits IconBase {
    commands: "M 12 3 L 12 15 M 6 9 L 12 15 L 18 9 M 4 19 L 20 19";
}

export component IconClose inherits IconBase {
    commands: "M 5 5 L 19 19 M 19 5 L 5 19";
}
